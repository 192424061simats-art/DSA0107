#include <iostream>
using namespace std;
int main() {
    int a = 5;
    cout << "Pre Increment (++a): " << ++a << endl;
    a = 5;
    cout << "Post Increment (a++): " << a++ << endl;
    cout << "Value after Post Increment: " << a << endl;
    int b = 5;
    cout << "Pre Decrement (--b): " << --b << endl;
    b = 5;
    cout << "Post Decrement (b--): " << b-- << endl;
    cout << "Value after Post Decrement: " << b << endl;
    return 0;
}
